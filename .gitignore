# ── Safety net ────────────────────────────────────────────────────────────
# Raw recon captures may contain the box serial, LAN MACs, the WAN IP,
# session tokens, phone numbers. They NEVER get committed. Scrubbed copies
# live in recon/capture/ (which IS committed).
recon/raw/

